# ============================================================
#  InsBinomo — .htaccess
#  Clean URLs: hides index.php and .php extensions from links
# ============================================================

Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /InsBinomo/

    # ----------------------------------------------------------
    # 1. Redirect /index.php → / (remove index.php from address bar)
    # ----------------------------------------------------------
    RewriteCond %{THE_REQUEST} \s/+InsBinomo/index\.php[\s?] [NC]
    RewriteRule ^index\.php$ /InsBinomo/ [R=301,L]

    # ----------------------------------------------------------
    # 2. Allow real files and directories to be served as-is
    #    (assets, JS, CSS, images, API endpoints, etc.)
    # ----------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ----------------------------------------------------------
    # 3. Extension-less PHP URLs: /pagename → pagename.php
    #    So you can link to pages without .php in the address
    # ----------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/]+)/?$ $1.php [L]

    # ----------------------------------------------------------
    # 4. Fallback: serve index.php for all other unmatched requests
    # ----------------------------------------------------------
    RewriteRule ^ index.php [L]
</IfModule>

# ----------------------------------------------------------
#  Block direct access to sensitive file types
# ----------------------------------------------------------
<FilesMatch "\.(log|sql|env|ini|sh|bat|bak|config)$">
    Require all denied
</FilesMatch>

# Block readme / plain text info files
<FilesMatch "^(readme|README|\.git|\.env)">
    Require all denied
</FilesMatch>

# ----------------------------------------------------------
#  Security Headers (requires mod_headers)
# ----------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------
#  Custom Error Pages
# ----------------------------------------------------------
ErrorDocument 403 /InsBinomo/index.php
ErrorDocument 404 /InsBinomo/index.php
